generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String   @id @default(cuid())
  firstName         String
  lastName          String
  phone             String   @unique
  email             String   @unique
  passwordHash      String?
  instagram         String?
  totalPoints       Int      @default(0)
  predictionPoints  Int      @default(0)
  bonusPoints       Int      @default(0)
  achievementPoints Int      @default(0)
  spentPoints       Int      @default(0)
  referralPoints    Int      @default(0)
  referralCode      String?  @unique
  referredById      String?
  earlyBirdGranted  Boolean  @default(false)
  hardcoreMode           Boolean  @default(false)
  isBlocked              Boolean  @default(false)
  emailUnsubscribed      Boolean  @default(false)
  acceptedTerms     Boolean  @default(false)
  registrationIp    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  referredBy            User?    @relation("UserReferrals", fields: [referredById], references: [id])
  referrals             User[]   @relation("UserReferrals")

  predictions           Prediction[]
  groupPredictions      GroupPrediction[]
  bracketPredictions    BracketPrediction[]
  specialPredictions    SpecialPrediction[]
  bonuses               UserBonus[]
  redemptions           PrizeRedemption[]
  purchaseCodes         PurchaseCode[]
  virtualAlbumInterests VirtualAlbumInterest[]
  userAchievements      UserAchievement[]
  notifications         Notification[]
  createdSquads         Squad[]       @relation("SquadCreator")
  squadMemberships      SquadMember[]
  squadInvitesSent      SquadInvite[] @relation("SquadInviteSent")
  squadInvitesReceived  SquadInvite[] @relation("SquadInviteReceived")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs AuditLog[]
}

model WorldCupGroup {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teams                Team[]
  matches              Match[]
  groupPredictions     GroupPrediction[]
  squadGroupPredictions SquadGroupPrediction[]
}

model Team {
  id         String  @id @default(cuid())
  name       String
  code       String  @unique
  flagUrl    String?
  groupId    String?
  externalId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group              WorldCupGroup?      @relation(fields: [groupId], references: [id])
  homeMatches        Match[]             @relation("HomeTeam")
  awayMatches        Match[]             @relation("AwayTeam")
  wonMatches         Match[]             @relation("WinnerTeam")
  groupFirsts        GroupPrediction[]   @relation("FirstTeam")
  groupSeconds       GroupPrediction[]   @relation("SecondTeam")
  groupThirds        GroupPrediction[]   @relation("ThirdTeam")
  bracketPredictions BracketPrediction[]
  squadGroupFirsts   SquadGroupPrediction[] @relation("SquadFirstTeam")
  squadGroupSeconds  SquadGroupPrediction[] @relation("SquadSecondTeam")
  squadGroupThirds   SquadGroupPrediction[] @relation("SquadThirdTeam")
  squadBracketPreds  SquadBracketPrediction[]
}

model Match {
  id              String    @id @default(cuid())
  externalId      String?
  provider        String?
  matchCode       String    @unique
  phase           String
  groupId         String?
  homeTeamId      String?
  awayTeamId      String?
  homePlaceholder String?
  awayPlaceholder String?
  venue           String?
  startDate       DateTime?
  homeScore       Int?
  awayScore       Int?
  realOutcome     String?
  winnerTeamId    String?
  status          String    @default("scheduled")
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  group            WorldCupGroup? @relation(fields: [groupId], references: [id])
  homeTeam         Team?          @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam         Team?          @relation("AwayTeam", fields: [awayTeamId], references: [id])
  winnerTeam       Team?          @relation("WinnerTeam", fields: [winnerTeamId], references: [id])
  predictions      Prediction[]
  events           MatchEvent[]
  squadPredictions SquadPrediction[]
}

model Prediction {
  id                    String    @id @default(cuid())
  userId                String
  matchId               String
  predictedOutcome      String?
  predictedWinnerTeamId String?
  predictedHomeScore    Int?
  predictedAwayScore    Int?
  pointsEarned          Int       @default(0)
  status                String    @default("editable")
  lockedAt              DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
  @@index([userId])
  @@index([matchId])
}

model GroupPrediction {
  id           String    @id @default(cuid())
  userId       String
  groupId      String
  firstTeamId  String?
  secondTeamId String?
  thirdTeamId  String?
  pointsEarned Int       @default(0)
  isLocked     Boolean   @default(false)
  lockedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user       User          @relation(fields: [userId], references: [id])
  group      WorldCupGroup @relation(fields: [groupId], references: [id])
  firstTeam  Team?         @relation("FirstTeam", fields: [firstTeamId], references: [id])
  secondTeam Team?         @relation("SecondTeam", fields: [secondTeamId], references: [id])
  thirdTeam  Team?         @relation("ThirdTeam", fields: [thirdTeamId], references: [id])

  @@unique([userId, groupId])
  @@index([userId])
}

model BracketPrediction {
  id              String    @id @default(cuid())
  userId          String
  phase           String
  matchSlot       String
  predictedTeamId String?
  pointsEarned    Int       @default(0)
  isLocked        Boolean   @default(false)
  lockedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user          User  @relation(fields: [userId], references: [id])
  predictedTeam Team? @relation(fields: [predictedTeamId], references: [id])

  @@unique([userId, phase, matchSlot])
  @@index([userId])
}

model SpecialPrediction {
  id             String   @id @default(cuid())
  userId         String
  type           String
  predictedValue String
  pointsEarned   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

model PointRule {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  points    Int
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Prize {
  id             String    @id @default(cuid())
  name           String
  description    String
  imageUrl       String?
  requiredPoints Int
  stock          Int       @default(0)
  sponsorId      String?
  active         Boolean   @default(true)
  featured       Boolean   @default(false)
  sortOrder      Int       @default(0)
  prizeType      String    @default("physical")
  maxPerUser     Int?
  maxTotal       Int?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sponsor     Sponsor?          @relation(fields: [sponsorId], references: [id])
  redemptions PrizeRedemption[]
}

model PrizeRedemption {
  id          String   @id @default(cuid())
  userId      String
  prizeId     String
  pointsSpent Int
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  prize Prize @relation(fields: [prizeId], references: [id])
}

model BonusAction {
  id               String   @id @default(cuid())
  name             String
  description      String
  points           Int
  multiplier       Float    @default(1)
  sponsorId        String?
  requiresApproval Boolean  @default(true)
  active           Boolean  @default(true)
  limitPerUser     Int?
  limitGlobal      Int?
  actionUrl           String?
  requiredHandles     String?
  allowMultipleClaims Boolean  @default(false)
  imageUrl            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sponsor     Sponsor?    @relation(fields: [sponsorId], references: [id])
  userBonuses UserBonus[]
}

model UserBonus {
  id            String   @id @default(cuid())
  userId        String
  bonusActionId String
  status        String   @default("pending")
  evidenceUrl   String?
  socialHandles String?
  pointsEarned  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  bonusAction BonusAction @relation(fields: [bonusActionId], references: [id])

  @@index([userId])
  @@index([bonusActionId])
}

model PurchaseCode {
  id         String    @id @default(cuid())
  code       String    @unique
  type       String    @default("purchase")
  points     Int
  status     String    @default("available")
  userId     String?
  notes      String?
  redeemedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model VirtualAlbumInterest {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Sponsor {
  id           String  @id @default(cuid())
  name         String
  logoUrl      String?
  description  String?
  websiteUrl   String?
  instagramUrl String?
  tiktokUrl    String?
  youtubeUrl   String?
  active       Boolean @default(true)
  showInHome   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prizes       Prize[]
  bonusActions BonusAction[]
}

model SponsorInquiry {
  id          String   @id @default(cuid())
  name        String
  brand       String
  email       String
  phone       String?
  instagram   String?
  reason      String
  offer       String
  message     String?
  status      String   @default("pending")
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SyncLog {
  id             String   @id @default(cuid())
  provider       String
  action         String
  endpoint       String?
  status         String
  message        String?
  requestCount   Int      @default(0)
  updatedMatches Int      @default(0)
  createdAt      DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  entity    String
  entityId  String?
  createdAt DateTime @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
}

model Standing {
  id             String   @id @default(cuid())
  season         String
  group          String
  rank           Int
  teamExternalId String
  teamName       String
  teamLogo       String?
  points         Int      @default(0)
  played         Int      @default(0)
  won            Int      @default(0)
  drawn          Int      @default(0)
  lost           Int      @default(0)
  goalsFor       Int      @default(0)
  goalsAgainst   Int      @default(0)
  goalsDiff      Int      @default(0)
  form           String?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@unique([season, group, teamExternalId])
}

model TopScorer {
  id            String   @id @default(cuid())
  season        String
  externalId    String
  rank          Int      @default(0)
  name          String
  photo         String?
  teamName      String?
  teamLogo      String?
  goals         Int      @default(0)
  assists       Int      @default(0)
  gamesPlayed   Int      @default(0)
  minutesPlayed Int      @default(0)
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([season, externalId])
}

model MatchEvent {
  id         String   @id @default(cuid())
  matchId    String
  minute     Int?
  extraTime  Int?
  teamId     String?
  teamName   String?
  playerName String?
  assistName String?
  eventType  String
  detail     String?
  comments   String?
  createdAt  DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id])

  @@index([matchId])
}

model AchievementRule {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String
  points      Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userAchievements UserAchievement[]
}

model UserAchievement {
  id                String   @id @default(cuid())
  userId            String
  achievementRuleId String
  pointsEarned      Int
  awardedAt         DateTime @default(now())
  createdAt         DateTime @default(now())

  user            User            @relation(fields: [userId], references: [id])
  achievementRule AchievementRule @relation(fields: [achievementRuleId], references: [id])

  @@unique([userId, achievementRuleId])
}

model WeeklyRaffle {
  id              String   @id @default(cuid())
  title           String
  description     String?
  prize           String
  scheduledAt     DateTime
  status          String   @default("upcoming")
  winnerName      String?
  winnerInstagram String?
  imageUrl        String?
  bonusActionId   String?
  prizeId         String?
  earlyBirdCutoff DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Squads (private friend competitions) ─────────────────────────────────────

model Squad {
  id          String   @id @default(cuid())
  name        String
  description String?
  inviteCode  String   @unique
  createdBy   String
  isHardcore  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator    User             @relation("SquadCreator", fields: [createdBy], references: [id])
  members    SquadMember[]
  invites    SquadInvite[]
  prizes        SquadPrize[]
  pointRules    SquadPointRule[]
  deleteRequest SquadDeleteRequest?
}

model SquadMember {
  id          String   @id @default(cuid())
  squadId     String
  userId      String
  role        String   @default("member")
  totalPoints Int      @default(0)
  spentPoints Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  squad        Squad                    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  user         User                     @relation(fields: [userId], references: [id])
  predictions  SquadPrediction[]
  groupPreds   SquadGroupPrediction[]
  bracketPreds SquadBracketPrediction[]
  redemptions  SquadRedemption[]

  @@unique([squadId, userId])
  @@index([userId])
}

model SquadInvite {
  id            String   @id @default(cuid())
  squadId       String
  invitedBy     String
  invitedUserId String
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  squad       Squad @relation(fields: [squadId], references: [id], onDelete: Cascade)
  inviter     User  @relation("SquadInviteSent", fields: [invitedBy], references: [id])
  invitedUser User  @relation("SquadInviteReceived", fields: [invitedUserId], references: [id])

  @@unique([squadId, invitedUserId])
}

model SquadPointRule {
  id      String @id @default(cuid())
  squadId String
  key     String
  points  Int

  squad Squad @relation(fields: [squadId], references: [id], onDelete: Cascade)

  @@unique([squadId, key])
}

model SquadPrediction {
  id                 String   @id @default(cuid())
  memberId           String
  matchId            String
  predictedOutcome   String?
  predictedHomeScore Int?
  predictedAwayScore Int?
  pointsEarned       Int      @default(0)
  isLocked           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  member SquadMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  match  Match       @relation(fields: [matchId], references: [id])

  @@unique([memberId, matchId])
}

model SquadGroupPrediction {
  id           String   @id @default(cuid())
  memberId     String
  wcGroupId    String
  firstTeamId  String?
  secondTeamId String?
  thirdTeamId  String?
  pointsEarned Int      @default(0)
  isLocked     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  member     SquadMember   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  wcGroup    WorldCupGroup @relation(fields: [wcGroupId], references: [id])
  firstTeam  Team?         @relation("SquadFirstTeam", fields: [firstTeamId], references: [id])
  secondTeam Team?         @relation("SquadSecondTeam", fields: [secondTeamId], references: [id])
  thirdTeam  Team?         @relation("SquadThirdTeam", fields: [thirdTeamId], references: [id])

  @@unique([memberId, wcGroupId])
}

model SquadBracketPrediction {
  id              String   @id @default(cuid())
  memberId        String
  phase           String
  matchSlot       String
  predictedTeamId String?
  pointsEarned    Int      @default(0)
  isLocked        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  member        SquadMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  predictedTeam Team?       @relation(fields: [predictedTeamId], references: [id])

  @@unique([memberId, phase, matchSlot])
}

model SquadPrize {
  id          String   @id @default(cuid())
  squadId     String
  name        String
  description String?
  pointsCost  Int
  stock       Int      @default(-1)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  squad       Squad             @relation(fields: [squadId], references: [id], onDelete: Cascade)
  redemptions SquadRedemption[]
}

model SquadRedemption {
  id          String   @id @default(cuid())
  memberId    String
  prizeId     String
  pointsSpent Int
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  member SquadMember @relation(fields: [memberId], references: [id])
  prize  SquadPrize  @relation(fields: [prizeId], references: [id])
}

model SquadDeleteRequest {
  id          String   @id @default(cuid())
  squadId     String   @unique
  requestedBy String
  createdAt   DateTime @default(now())

  squad Squad             @relation(fields: [squadId], references: [id], onDelete: Cascade)
  votes SquadDeleteVote[]
}

model SquadDeleteVote {
  id        String   @id @default(cuid())
  requestId String
  userId    String
  approve   Boolean
  createdAt DateTime @default(now())

  request SquadDeleteRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, userId])
}

// ── Notifications ─────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  data      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}
